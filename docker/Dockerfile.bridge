FROM node:20

# Corporate SSL certificate
COPY docker/FLOMcAfeeWG.crt /usr/local/share/ca-certificates/FLOMcAfeeWG.crt
RUN update-ca-certificates
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt

# CLI tools
RUN npm install -g @openai/codex@latest || true
RUN npm install -g @anthropic-ai/claude-code@latest || true

RUN useradd -m -s /bin/bash bridge \
 && echo '{}' > /home/bridge/.claude.json \
 && chown bridge:bridge /home/bridge/.claude.json

WORKDIR /app
COPY docker/bridge-server.mjs /app/bridge-server.mjs
COPY docker/bridge-entrypoint.sh /app/bridge-entrypoint.sh

EXPOSE 9876
CMD ["/app/bridge-entrypoint.sh"]
